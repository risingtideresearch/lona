{
  "name": "lona-geom",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/lona-geom.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "test": "vitest run",
    "test-watch": "vitest",
    "dev": "vite",
    "watch": "watchexec -w src vite build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint --max-warnings 0 .",
    "typecheck": "tsc -b",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "formatcheck": "prettier --ignore-path ../../.prettierignore --check .",
    "check": "npm run typecheck; l=$?; npm run lint; r=$?; npm run formatcheck && exit $((l || r))"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^25.0.6",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.9",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "lona": "*"
  }
}
