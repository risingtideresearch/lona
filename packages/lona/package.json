{
  "name": "lona",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/lona.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/lona.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node ../../scripts/clean.mjs dist",
    "test": "vitest run",
    "test:integration": "vitest run src/eval/real-world-eval.integration.ts --maxWorkers=1",
    "test:gpu": "LONA_TEST_GPU=1 npm run test:integration",
    "test-watch": "vitest",
    "dev": "vite",
    "watch": "npm run clean && vite build --watch --mode debug",
    "build": "npm run clean && tsc --noEmit && vite build",
    "build:debug": "npm run clean && vite build --mode debug",
    "preview": "vite preview",
    "lint": "eslint --max-warnings 0 .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "formatcheck": "prettier --ignore-path ../../.prettierignore --check .",
    "check": "npm run typecheck && npm run lint && npm run test && npm run formatcheck"
  },
  "dependencies": {
    "decimal.js": "^10.5.0",
    "webgpu": "^0.4.0"
  }
}
